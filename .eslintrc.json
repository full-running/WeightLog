{
    "env": {
        "browser": true,
        "es2021": true
    },
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "script"
    },
    "rules": {
        "strict": [
            "error",
            "global"
        ],
        "no-var": "error",
        "no-unused-vars": "warn",
        "eqeqeq": "error",
        "no-console": "warn"
    }
}